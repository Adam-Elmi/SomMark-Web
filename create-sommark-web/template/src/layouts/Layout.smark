[DOCTYPE!]
[html = lang: "en"]
  [head]
    [meta = charset: "UTF-8"!]
    [meta = name: "viewport", content: "width=device-width, initial-scale=1.0"!]
    [title]v{title}[end]
    [meta = name: "description", content: v{description}!]
    [link = rel: "stylesheet", href: "/src/styles/style.css"!]
    [link = rel: "icon", href: "/src/assets/sommark-web-logo.png", type: "image/png"!]
  [end]

  [body]
    [div = id: "app"]
      [slot][end]
    [end]
  [end]
[end]
