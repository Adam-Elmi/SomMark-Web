{
  "name": "sommark-web",
  "version": "2.0.0",
  "description": "SomMark Web is a lightweight web framework and high-performance Static Site Generation using Vite and the SomMark engine.",
  "keywords": [
    "framework",
    "vite",
    "sommark-web",
    "sommark",
    "ssg",
    "static-site-generator"
  ],
  "author": "Adam Elmi Eid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adam-Elmi/SomMark-Web.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "private": false,
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "vite": "^8.0.10"
  },
  "peerDependencies": {
    "typescript": "^5",
    "vite": "^5.0.0 || ^6.0.0 || ^8.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "sommark": "^4.1.0"
  }
}
